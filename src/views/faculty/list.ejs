<%- include('../partials/header') %>

<main>
  <h1>Faculty Directory</h1>

  <div class="faculty-sort">
    <span>Sort by:</span>
    <a href="/faculty" class="<%= currentSort === 'name' ? 'active' : '' %>">Name</a>
    <a href="/faculty?sort=department" class="<%= currentSort === 'department' ? 'active' : '' %>">Department</a>
    <a href="/faculty?sort=title" class="<%= currentSort === 'title' ? 'active' : '' %>">Title</a>
  </div>

  <div class="faculty-list">
    <% Object.values(faculty).forEach(member => { %>
      <div class="faculty-card">
        <a href="/faculty/<%= member.slug %>">
          <img class="faculty-photo" src="/images/faculty/<%= member.slug %>.jpg" />
        </a>
        <div>
          <h3><a href="/faculty/<%= member.slug %>"><%= member.name %></a></h3>
          <p class="faculty-title"><%= member.title %> • <%= member.department %></p>
        </div>
      </div>
    <% }); %>
  </div>
</main>

<%- include('../partials/footer') %>
