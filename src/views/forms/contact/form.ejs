<%- include('../../partials/header') %>

<main>
  <h1>Contact Us</h1>
  <p>
    Have questions or feedback? Send us a message using the form below and we'll get back to you as soon as possible
  </p>

  <form action="/contact" method="POST" class="contact-form">
    <div class="form-group">
      <label for="subject">Subject</label>
      <input
        type="text"
        name="subject"
        placeholder="What is this message about?"
        id="subject"
        minlength="2"
        required
      />
    </div>

    <div class="form-group">
      <label for="email">Email (optional)</label>
      <input
        type="email"
        name="email"
        placeholder="We'd love to get back to you"
        id="email"
      />
    </div>

    <div class="form-group">
      <label for="message">Message</label>
      <textarea
        name="message"
        id="message"
        rows="6"
        placeholder="Please provide details about your question or feedback..."
        minlength="10"
        required
      ></textarea>
    </div>

    <button type="submit">Send Message</button>
  </form>
</main>

<%- include('../../partials/footer') %>
